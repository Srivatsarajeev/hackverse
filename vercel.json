{
  "cleanUrls": true,
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "/api"
    },
    {
      "source": "/admin",
      "destination": "/neo-tokyo-shadow-control"
    },
    {
      "source": "/admin/",
      "destination": "/neo-tokyo-shadow-control"
    }
  ]
}
